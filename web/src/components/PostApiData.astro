---
export interface Props {
  id: string;
}

const { id } = Astro.props;

let postData = null;
let error = null;

try {
  // Astro components run on the server, so fetch() requires an absolute URL.
  // We use the API_URL environment variable here directly.
  const apiUrl = import.meta.env.API_URL || "http://127.0.0.1:8000";
  const response = await fetch(`${apiUrl}/posts/${id}`);
  if (!response.ok) {
    throw new Error(`Failed to fetch data: ${response.status}`);
  }
  postData = await response.json();
} catch (e) {
  error = e.message;
}
---

<div
  class="my-8 overflow-hidden rounded-2xl bg-gradient-to-br from-slate-800 to-slate-900 border border-slate-700 shadow-2xl"
>
  <div
    class="px-6 py-4 border-b border-slate-700 bg-slate-800/50 flex items-center justify-between"
  >
    <div class="flex items-center space-x-3">
      <div class="w-3 h-3 rounded-full bg-emerald-500 animate-pulse"></div>
      <h3 class="text-lg font-semibold text-slate-100 m-0">Live API Data</h3>
    </div>
    <span
      class="text-xs font-medium text-slate-400 bg-slate-800 px-2.5 py-1 rounded-full border border-slate-700"
      >/posts/&#123;id&#125;</span
    >
  </div>

  <div class="p-6">
    {
      error ? (
        <div class="text-rose-400 font-mono text-sm">
          Error fetching data: {error}
        </div>
      ) : postData ? (
        <div class="space-y-4">
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">
              Title
            </p>
            <p class="text-slate-200 font-medium text-lg m-0">
              {postData.title}
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">
                Slug
              </p>
              <p class="text-slate-300 font-mono text-sm bg-slate-950/50 rounded px-2 py-1 inline-block m-0">
                {postData.slug}
              </p>
            </div>
            <div>
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">
                Published
              </p>
              <p class="text-slate-300 text-sm m-0">
                {new Date(postData.published_at).toLocaleDateString()}
              </p>
            </div>
          </div>

          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">
              Data Path
            </p>
            <div class="flex items-center space-x-2 text-slate-300 font-mono text-sm bg-slate-950/50 rounded p-2 m-0">
              <svg
                class="w-4 h-4 text-slate-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  transform="translate(6, 6) scale(0.5)"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1"
                  d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
                />
              </svg>
              <span>{postData.data_path}</span>
            </div>
          </div>

          <div class="pt-2">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
              Content Preview
            </p>
            <p class="text-slate-400 text-sm italic border-l-2 border-indigo-500 pl-3 m-0">
              {postData.content}
            </p>
          </div>
        </div>
      ) : (
        <div class="text-slate-400">Loading...</div>
      )
    }
  </div>
</div>
