---
import UserCreateForm from '../../components/UserCreateForm';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="en">
  <head>
    <BaseHead title="User Configuration | DuckOps" description="Manage DuckOps user config" />
  </head>
  <body class="bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100">
    <Header />
    <main class="container mx-auto px-4 py-12">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-extrabold text-slate-100 tracking-tight">User Configuration</h1>
        <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">Manage users for the DuckOps backend. In a production environment, this would be protected by authentication.</p>
      </div>

      <UserCreateForm client:load />
    </main>
    <Footer />
  </body>
</html>
